.github
.gitignore
.git
.vscode
*.xcf
*.svg
*.lmp
*.lmps
*.vsix
*.py
*.map
*.d.ts

# Source files
src/
dist/extension.js.map
tsconfig.json
webpack.config.js
package-lock.json

# Build tools
rst2json/
scripts/
out/

# Documentation (keep README for users)
RELEASE.md
CHANGELOG.md
CODE_OF_CONDUCT.md

# Unused images (we only use logo2.png)
imgs/autocomplete.gif
imgs/dashboard.gif
imgs/doc_panel.gif
imgs/hover.gif
imgs/lammps-lng-anim.gif
imgs/lint.gif
imgs/vsc_lammps.png

# Unused themes
css/

# Exclude most node_modules - only keep essential runtime files
node_modules/**
!node_modules/markdown-it
!node_modules/markdown-it/package.json
!node_modules/markdown-it/index.js
!node_modules/markdown-it/lib/**

!node_modules/mathjax-node
!node_modules/mathjax-node/package.json
!node_modules/mathjax-node/lib/**

!node_modules/vscode-oniguruma
!node_modules/vscode-oniguruma/package.json
!node_modules/vscode-oniguruma/release/*.wasm
!node_modules/vscode-oniguruma/release/onig.js

!node_modules/vscode-textmate
!node_modules/vscode-textmate/package.json
!node_modules/vscode-textmate/release
!node_modules/vscode-textmate/release/main.js

# Exclude common unnecessary dirs in node_modules
node_modules/**/.github
node_modules/**/test
node_modules/**/tests
node_modules/**/.git
node_modules/**/.gitignore
node_modules/**/*.md

# Exclude rst documentation
rst/

